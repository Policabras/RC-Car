# Collector identity
EDGE_ID=pi_robot_01
DEBUG=true

# Remote MQTT broker
MQTT_HOST=192.168.0.106
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=pi_robot_01_collector
MQTT_KEEPALIVE=30
MQTT_BASE_TOPIC=telemetry

# Local UDP input on Raspberry (optional)
UDP_ENABLED=false
UDP_BIND_HOST=0.0.0.0
UDP_BIND_PORT=9100

# Local serial input on Raspberry (ESP32 by USB)
SERIAL_ENABLED=true
SERIAL_PORTS=/dev/ttyUSB0,/dev/ttyUSB1
SERIAL_BAUDRATE=115200
SERIAL_TIMEOUT_MS=200
SERIAL_RECONNECT_DELAY_MS=1500

# Local storage
SQLITE_PATH=./telemetry.db

# Publisher behavior
PUBLISH_BATCH_SIZE=100
PUBLISH_POLL_INTERVAL_MS=200

# Raspberry local telemetry period
SYSTEM_SAMPLE_PERIOD_MS=1000