[Unit]
Description=Telemetry Collector
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=charly
Group=video
WorkingDirectory=/home/charly/projects/RC-Car/src/raspberry_testing/telemetry_collector
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/charly/projects/RC-Car/.venv/bin/python /home/charly/projects/RC-Car/src/raspberry_testing/telemetry_collector/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
